# JWT signing secret for admin sessions (required in production)
JWT_SECRET=

# Vercel KV (optional locally — falls back to data/*.json files if unset)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Gmail account used to send mailing-list notification emails.
# GMAIL_APP_PASSWORD is a 16-character "app password" from your Google
# Account (Security > 2-Step Verification > App passwords), NOT your normal
# Gmail password.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: sender identity shown to recipients. Defaults to GMAIL_USER.
MAIL_FROM="Andrew's Story Blog <yourgmail@gmail.com>"
