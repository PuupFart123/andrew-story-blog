# JWT signing secret for admin sessions (required in production)
JWT_SECRET=

# Vercel KV (optional locally — falls back to data/*.json files if unset)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend API key for mailing-list notification emails (get one at resend.com)
RESEND_API_KEY=

# Optional: sender identity for notification emails.
# Until you verify your own domain on Resend, must stay on their shared
# onboarding@resend.dev address.
MAIL_FROM="Andrew's Story Blog <onboarding@resend.dev>"
